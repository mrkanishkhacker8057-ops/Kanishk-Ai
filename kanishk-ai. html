            tokens: countTokens(message)
        };

        chat.messages.push(userMsg);

        // Get AI model preference
        const model = aiModel || req.user.preferredAI || selectAIModel();

        // Prepare messages for AI
        const aiMessages = chat.messages.map(msg => ({
            role: msg.role === 'user' ? 'user' : 'assistant',
            content: msg.content
        }));

        // Call AI Model
        const startTime = Date.now();
        const aiResponse = await callAIModel(
            model,
            aiMessages,
            req.user.settings.temperature,
            2000
        );
        const responseTime = Date.now() - startTime;

        // Add AI response
        const assistantMsg = {
            id: 'msg_' + Date.now(),
