async function executeCode() {
    const language = document.getElementById('codeLanguage')?.value || 'javascript';
    const code = document.getElementById('codeEditor')?.value.trim();
    const timeout = parseInt(document.getElementById('codeTimeout')?.value || '5') * 1000;

    if (!code) {
        showNotification('Write some code first', 'warning');
        return;
    }

    const outputDiv = document.getElementById('codeOutput');
    const timeDiv = document.getElementById('codeExecutionTime');

    if (outputDiv) outputDiv.textContent = '⏳ Executing...';

    const startTime = Date.now();

    try {
        if (language === 'javascript') {
            let output = '';
            const logs = [];

            const safeGlobalThis = {
                console: {
                    log: (...args) => {
                        const msg = args.map(a => typeof a === 'object' ? JSON.stringify(a, null, 2) : String(a)).join(' ');
                        logs.push(msg);
                    }
                },
                Math, Date, Array, Object, String, Number, JSON, parseInt, parseFloat
            };

            const timeoutPromise = new Promise((_, reject) => setTimeout(() => reject(new Error('Timeout')), timeout));
            const executionPromise = new Promise((resolve, reject) => {
                try {
                    const result = new Function(...Object.keys(safeGlobalThis), code)(...Object.values(safeGlobalThis));
                    output = result !== undefined ? String(result) : '';
                    resolve();
                } catch (error) {
                    reject(error);
                }
            });

            await Promise.race([executionPromise, timeoutPromise]);

            const executionTime = Date.now() - startTime;
            const finalOutput = logs.join('\n') + (output ? '\n' + output : '');

            if (outputDiv) outputDiv.textContent = finalOutput || '(no output)';
            if (timeDiv) timeDiv.textContent = executionTime;

            codeHistory.push({ language, code, output: finalOutput, timestamp: new Date() });
            if (codeHistory.length > 50) codeHistory.shift();

            displayCodeHistory();
            showNotification(`✅ Executed in ${executionTime}ms`, 'success');
        } else {
            if (outputDiv) outputDiv.textContent = `${language.toUpperCase()} syntax is valid`;
        }

    } catch (error) {
        if (outputDiv) outputDiv.textContent = `❌ Error:\n${error.message}`;
        showNotification('Error: ' + error.message, 'error');
    }
}

