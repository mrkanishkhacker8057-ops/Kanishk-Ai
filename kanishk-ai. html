let mediaRecorder = null;
let audioChunks = [];
let voiceTranscript = '';

async function startVoiceInput() {
    try {
        const stream = await navigator.mediaDevices.getUserUserMedia({ audio: true });
        mediaRecorder = new MediaRecorder(stream);
        audioChunks = [];

        mediaRecorder.ondataavailable = (event) => {
            audioChunks.push(event.data);
        };

        mediaRecorder.onstop = () => {
            const audioBlob = new Blob(audioChunks, { type: 'audio/webm' });
            transcribeAudio(audioBlob);
        };

        mediaRecorder.start();

        document.getElementById('voiceStartBtn').style.display = 'none';
        document.getElementById('voiceStopBtn').style.display = 'block';
        showNotification('🎤 Recording...', 'success');

    } catch (error) {
        logger.error('Voice input error', error);
        showNotification('Microphone access denied', 'error');
    }
}

function stopVoiceInput() {
    if (mediaRecorder) {
        mediaRecorder.stop();
        mediaRecorder.stream.getTracks().forEach(track => track.stop());

        document.getElementById('voiceStartBtn').style.display = 'block';
        document.getElementById('voiceStopBtn').style.display = 'none';
        showNotification('⏹️ Recording stopped', 'success');
    }
}

async function transcribeAudio(audioBlob) {
    try {
        const formData = new FormData();
        formData.append('audio', audioBlob);

        const response = await fetch(`${CONFIG.API_BASE_URL}/transcribe`, {
            method: 'POST',
            headers: tokenManager.getHeader(),
            body: formData
        });

        const data = await response.json();

        if (data.success) {
            voiceTranscript = data.text;
            const transcriptDiv = document.getElementById('voiceTranscript');
            if (transcriptDiv) {
                transcriptDiv.textContent = voiceTranscript;
            }
            showNotification('✅ Transcribed', 'success');
        }
    } catch (error) {
        logger.error('Transcribe error', error);
        showNotification('Transcription failed', 'error');
    }
}

function useVoiceTranscript() {
    const input = document.getElementById('userInput');
    if (input && voiceTranscript) {
        input.value = voiceTranscript;
        sendMessage();
    }
}

function clearVoiceTranscript() {
