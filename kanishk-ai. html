function displayMessage(role, content) {
    const chatMessages = document.getElementById('chatMessages');
    if (!chatMessages) return;

    // Remove empty state if exists
    const emptyState = chatMessages.querySelector('.empty-state');
    if (emptyState) emptyState.remove();

    const messageDiv = document.createElement('div');
    messageDiv.className = `message ${role}`;

    const bubbleDiv = document.createElement('div');
    bubbleDiv.className = 'message-bubble';

    try {
        const md = marked.parse ? marked.parse(content) : content;
        const sanitized = DOMPurify.sanitize(md);
        bubbleDiv.innerHTML = sanitized;

        bubbleDiv.querySelectorAll('pre code').forEach(block => {
            try {
                if (window.hljs) {
                    hljs.highlightElement(block);
                }
            } catch (e) {}
        });
    } catch (e) {
        bubbleDiv.textContent = content;
    }

    messageDiv.appendChild(bubbleDiv);
    chatMessages.appendChild(messageDiv);
    chatMessages.scrollTop = chatMessages.scrollHeight;
}

function showTypingIndicator() {
    const chatMessages = document.getElementById('chatMessages');
    if (!chatMessages) return;

    const typingDiv = document.createElement('div');
    typingDiv.className = 'message ai';
    typingDiv.id = 'typingIndicator';
    typingDiv.innerHTML = `
        <div class="typing-indicator">
            <div style="width: 10px; height: 10px; background: var(--primary); border-radius: 50%; animation: typingAnimation 1.4s infinite;"></div>
            <div style="width: 10px; height: 10px; background: var(--primary); border-radius: 50%; animation: typingAnimation 1.4s infinite; animation-delay: 0.2s;"></div>
            <div style="width: 10px; height: 10px; background: var(--primary); border-radius: 50%; animation: typingAnimation 1.4s infinite; animation-delay: 0.4s;"></div>
        </div>
    `;
    chatMessages.appendChild(typingDiv);
    chatMessages.scrollTop = chatMessages.scrollHeight;
}

function removeTypingIndicator() {
    const indicator = document.getElementById('typingIndicator');
    if (indicator) indicator.remove();
}

async function sendMessage() {
    const input = document.getElementById('userInput');
    if (!input) return;

    const message = input.value.trim();

    if (!message) {
        showNotification('कुछ लिखें / Type something', 'warning');
        return;
    }

    if (!state.currentChatId) {
        showNotification('No chat selected', 'error');
        return;
    }

    if (state.isLoading) {
        showNotification('Already processing...', 'warning');
        return;
    }

    try {
        state.isLoading = true;
        const sendBtn = document.getElementById('sendBtn');
        if (sendBtn) sendBtn.disabled = true;

        // Display user message
        displayMessage('user', message);
        input.value = '';
        document.getElementById('charCount').textContent = '0';

        showTypingIndicator();
        
        const startTime = Date.now();

        // Send to backend
        const response = await apiClient.post('/chat/message', {
            chatId: state.currentChatId,
            message: message,
            aiModel: state.settings.preferredAI
        });

        const responseTime = Date.now() - startTime;
        removeTypingIndicator();

        if (response.success) {
            const aiResponse = response.data.aiResponse;
            displayMessage('assistant', aiResponse.content);

            // Update state
            state.messageHistory.push(response.data.userMessage);
            state.messageHistory.push(aiResponse);
            state.contextMemory.push({
                role: 'user',
                content: message
            });
            state.contextMemory.push({
                role: 'assistant',
                content: aiResponse.content
            });

            // Update analytics
            state.analytics.totalMessages++;
            state.analytics.totalResponses++;
            state.analytics.averageResponseTime = responseTime;
            state.analytics.totalTokens += response.data.tokensUsed;
            state.analytics.estimatedCost += response.data.cost;

            showNotification(`✅ Response in ${responseTime}ms`, 'success');
        }

    } catch (error) {
        logger.error('Send message error', error);
        removeTypingIndicator();
        displayMessage('error', '❌ Error: ' + error.message);
        showNotification('Error sending message', 'error');
        state.analytics.errorRate++;
    } finally {
        state.isLoading = false;
        const sendBtn = document.getElementById('sendBtn');
        if (sendBtn) sendBtn.disabled = !document.getElementById('userInput').value.trim();
    }
}

function handleInputKeydown(event) {
    if (event.key === 'Enter' && !event.shiftKey) {
        event.preventDefault();
        sendMessage();
    }
}

// Update char count and token estimate
document.addEventListener('DOMContentLoaded', () => {
    const userInput = document.getElementById('userInput');
    if (userInput) {
