    async request(method = 'GET', endpoint = '', data = null, options = {}) {
        const url = `${CONFIG.API_BASE_URL}${endpoint}`;
        const headers = {
            'Content-Type': 'application/json',
            ...tokenManager.getHeader(),
            ...options.headers
        };

        const config = {
            method,
            headers,
            timeout: options.timeout || CONFIG.REQUEST_TIMEOUT,
            ...options
        };

        if (data) {
            config.body = JSON.stringify(data);
        }

        try {
            logger.debug(`API Request: ${method} ${endpoint}`);
            
            const controller = new AbortController();
            const timeoutId = setTimeout(() => controller.abort(), config.timeout);

            const response = await fetch(url, { ...config, signal: controller.signal });
            clearTimeout(timeoutId);

            if (!response.ok) {
                if (response.status === 401) {
                    tokenManager.remove();
                    showAuthContainer();
                    throw new Error('Unauthorized');
                }
                const errorData = await response.json();
                throw new Error(errorData.message || `HTTP ${response.status}`);
            }

            const result = await response.json();
            logger.debug(`API Response: ${method} ${endpoint}`, result);
            return result;

        } catch (error) {
            logger.error(`API Error: ${method} ${endpoint}`, error);
            throw error;
        }
    },

    get: (endpoint, options = {}) => apiClient.request('GET', endpoint, null, options),
    post: (endpoint, data, options = {}) => apiClient.request('POST', endpoint, data, options),
    put: (endpoint, data, options = {}) => apiClient.request('PUT', endpoint, data, options),
    delete: (endpoint, options = {}) => apiClient.request('DELETE', endpoint, null, options)
};

