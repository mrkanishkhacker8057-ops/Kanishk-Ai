        try_files \$uri \$uri/ /index.html;
        expires 1h;
        add_header Cache-Control "public, max-age=3600";
    }
    
    # API routing
    location /api/ {
        proxy_pass http://backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade \$http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host \$host;
        proxy_set_header X-Real-IP \$remote_addr;
        proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto \$scheme;
        proxy_buffering off;
        proxy_request_buffering off;
        proxy_timeout 120s;
        proxy_connect_timeout 10s;
    }
    
    # Health check
    location /api/health {
        access_log off;
        proxy_pass http://backend;
    }
    
    # Static files
    location ~* \\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)\$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }
    
    # Deny hidden files
    location ~ /\\. {
        deny all;
        access_log off;
        log_not_found off;
    }
}
`,

    // WAF rules (Web Application Firewall)
    wafRules: {
        sqlInjection: {
            enabled: true,
            patterns: [
                /('|"|;|--|\/\*|\*\/|union|select|insert|update|delete|drop|create|alter)/gi
            ]
        },
        xss: {
            enabled: true,
            patterns: [
                /(<script|javascript:|onerror=|onload=|onclick=|on\w+\s*=)/gi
            ]
        },
        pathTraversal: {
            enabled: true,
            patterns: [
                /(\.\.|\/\.\.\/|\.\.%2f|%2e%2e%2f)/gi
            ]
        }
    },

    // SSL/TLS configuration
    sslConfig: {
        protocol: 'TLSv1.2',
        ciphers: 'HIGH:!aNULL:!MD5',
        certificates: {
            cert: '/etc/letsencrypt/live/kanishkai.com/fullchain.pem',
            key: '/etc/letsencrypt/live/kanishkai.com/privkey.pem'
        },
        dhParams: '/etc/nginx/ssl/dhparam.pem'
    }
};

