const BackupConfig = {
    // Backup schedule
    schedule: {
        hourly: '0 * * * *',
        daily: '0 2 * * *',
        weekly: '0 3 * * 0',
        monthly: '0 4 1 * *'
    },

    // Backup destinations
    destinations: {
        local: '/backups/local',
        aws: {
            bucket: 'kanishk-ai-backups',
            region: 'us-east-1',
            prefix: 'prod/'
        },
        gcp: {
            bucket: 'kanishk-ai-backups-gcp',
            prefix: 'prod/'
        },
        azure: {
            container: 'kanishk-ai-backups',
            storageAccount: 'kanishkaiv40'
        }
    },

    // Backup retention policy
    retention: {
        hourly: 24,    // Keep 24 hourly backups (1 day)
        daily: 7,      // Keep 7 daily backups (1 week)
        weekly: 4,     // Keep 4 weekly backups (1 month)
        monthly: 12    // Keep 12 monthly backups (1 year)
    },

    // Backup script (simplified)
    backupScript: `#!/bin/bash

set -e

TIMESTAMP=\$(date +%Y%m%d_%H%M%S)
BACKUP_DIR="/backups/\${TIMESTAMP}"
LOG_FILE="/var/log/backup-\${TIMESTAMP}.log"

mkdir -p \$BACKUP_DIR

echo "Starting backup at \$(date)" | tee -a \$LOG_FILE

# MongoDB backup
echo "Backing up MongoDB..." | tee -a \$LOG_FILE
mongodump --uri="mongodb://\${MONGO_USER}:\${MONGO_PASSWORD}@localhost:27017" \\
          --out=\$BACKUP_DIR/mongo >> \$LOG_FILE 2>&1

# Redis backup
echo "Backing up Redis..." | tee -a \$LOG_FILE
redis-cli BGSAVE >> \$LOG_FILE 2>&1
cp /var/lib/redis/dump.rdb \$BACKUP_DIR/redis_dump.rdb >> \$LOG_FILE 2>&1

# Application files backup
echo "Backing up application files..." | tee -a \$LOG_FILE
tar -czf \$BACKUP_DIR/app_files.tar.gz /app/uploads >> \$LOG_FILE 2>&1

# Upload to S3
echo "Uploading to S3..." | tee -a \$LOG_FILE
aws s3 sync \$BACKUP_DIR s3://\${AWS_BUCKET}/prod/\${TIMESTAMP}/ >> \$LOG_FILE 2>&1

# Upload to GCS
echo "Uploading to GCS..." | tee -a \$LOG_FILE
gsutil -m cp -r \$BACKUP_DIR gs://\${GCS_BUCKET}/prod/\${TIMESTAMP}/ >> \$LOG_FILE 2>&1

# Cleanup old backups
find /backups -type d -mtime +7 -exec rm -rf {} + 2>/dev/null || true

echo "Backup completed at \$(date)" | tee -a \$LOG_FILE
`
};

