async function initializeChat() {
    try {
        logger.info('Initializing chat');

        // Fetch all chats
        const response = await apiClient.get('/chat/all?limit=50');

        if (response.success) {
            state.allChats = response.data.chats || [];

            if (state.allChats.length === 0) {
                await createNewChat();
            } else {
                state.currentChatId = state.allChats[0]._id;
                await loadChat(state.currentChatId);
            }

            updateChatsList();
        }
    } catch (error) {
        logger.error('Initialize chat error', error);
        showNotification('Error loading chats', 'error');
    }
}

async function createNewChat() {
    try {
        state.isLoading = true;
        const response = await apiClient.post('/chat/create', {
            title: '💬 Chat - ' + new Date().toLocaleDateString('hi-IN')
        });

        if (response.success) {
            const newChat = response.data;
            state.allChats.unshift(newChat);
            state.currentChatId = newChat._id;
            state.currentChat = newChat;
            
            clearChatMessages();
            updateChatsList();
            closeDrawer();
            showNotification('✅ New chat created', 'success');
        }
    } catch (error) {
        logger.error('Create chat error', error);
        showNotification('Error creating chat', 'error');
    } finally {
        state.isLoading = false;
    }
}

async function loadChat(chatId) {
    try {
        state.isLoading = true;
        const response = await apiClient.get(`/chat/${chatId}`);

        if (response.success) {
            state.currentChat = response.data;
            state.currentChatId = chatId;
            state.messageHistory = response.data.messages || [];
            state.contextMemory = response.data.messages.map(msg => ({
                role: msg.role,
                content: msg.content,
                intent: msg.intent,
                sentiment: msg.sentiment
            })) || [];

            clearChatMessages();
            displayChatMessages();
            updateChatTitle();
        }
    } catch (error) {
        logger.error('Load chat error', error);
        showNotification('Error loading chat', 'error');
    } finally {
        state.isLoading = false;
    }
}

async function deleteChat(chatId) {
    if (!confirm('🚨 Delete this chat? This cannot be undone!')) return;

    try {
        const response = await apiClient.delete(`/chat/${chatId}`);

        if (response.success) {
            state.allChats = state.allChats.filter(chat => chat._id !== chatId);

            if (state.currentChatId === chatId) {
                if (state.allChats.length > 0) {
                    await loadChat(state.allChats[0]._id);
                } else {
                    await createNewChat();
                }
            }

            updateChatsList();
            showNotification('✅ Chat deleted', 'success');
        }
    } catch (error) {
        logger.error('Delete chat error', error);
        showNotification('Error deleting chat', 'error');
    }
}

